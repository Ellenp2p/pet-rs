{
  "demo_plugin": {
    "enabled": true,
    "log_level": "info",
    "max_events_per_second": 100,
    "dependencies": []
  },
  "stats_plugin": {
    "enabled": true,
    "track_purchases": true,
    "track_heals": true,
    "track_gold": true,
    "reset_interval": 3600,
    "dependencies": [
      {
        "plugin_id": "demo_plugin",
        "version_req": ">=1.0.0"
      }
    ]
  },
  "reader_plugin": {
    "enabled": true,
    "poll_interval": 10,
    "read_buffer_size": 1024,
    "data_sources": ["stats_plugin", "demo_plugin"],
    "dependencies": [
      {
        "plugin_id": "stats_plugin",
        "version_req": ">=1.0.0"
      }
    ]
  }
}
