{
  "demo_plugin": {
    "enabled": true,
    "log_level": "info",
    "max_events_per_second": 100,
    "dependencies": [],
    "permissions": [
      {
        "type": "full_access",
        "resource": "*",
        "denied": false
      }
    ]
  },
  "stats_plugin": {
    "enabled": true,
    "track_purchases": true,
    "track_heals": true,
    "track_gold": true,
    "reset_interval": 3600,
    "dependencies": [
      {
        "plugin_id": "demo_plugin",
        "version_req": ">=1.0.0"
      }
    ],
    "permissions": [
      {
        "type": "read_data",
        "resource": "*",
        "denied": false
      },
      {
        "type": "write_data",
        "resource": "*",
        "denied": false
      },
      {
        "type": "read_config",
        "resource": "track_*",
        "denied": false
      }
    ]
  },
  "reader_plugin": {
    "enabled": true,
    "poll_interval": 10,
    "read_buffer_size": 1024,
    "data_sources": ["stats_plugin", "demo_plugin"],
    "dependencies": [
      {
        "plugin_id": "stats_plugin",
        "version_req": ">=1.0.0"
      }
    ],
    "permissions": [
      {
        "type": "read_data",
        "resource": "purchase_count",
        "denied": false
      },
      {
        "type": "read_data",
        "resource": "heal_count",
        "denied": false
      },
      {
        "type": "read_data",
        "resource": "gold_earned",
        "denied": false
      },
      {
        "type": "write_data",
        "resource": "*",
        "denied": true
      },
      {
        "type": "access_plugin",
        "resource": "stats_plugin",
        "denied": false
      }
    ]
  }
}
